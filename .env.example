# Copy this file to .env and fill in your local secrets.
# Never commit the real .env file.

SILICONFLOW_API_KEY=
TELEGRAM_BOT_TOKEN=
# Optional. Defaults to the folder containing the YueYue Python files.
YUEYUE_ROOT_DIR=
YUEYUE_TURN_DEBOUNCE_SECONDS=5.5
# Optional model routing. Leave blank to use the strong default for every route.
YUEYUE_CHAT_MODEL=
YUEYUE_STRONG_MODEL=deepseek-ai/DeepSeek-V4-Pro
YUEYUE_TASK_MODEL=
YUEYUE_VISION_MODEL=
RUN_LIVE_TELEGRAM_SMOKE=0
